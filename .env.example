BOT_TOKEN=123456:ABCDEF
ADMIN_IDS=111111111,222222222
DB_PATH=data/bot.db
TZ=Europe/Moscow

# If 1: ignore notify_log and allow repeated notifications (useful during testing).
REPEAT_NOTIFY=1

# If 1: when a new sign-up post is created (or copy-pasted), notify subscribers
# about players that are already listed in that post.
NOTIFY_ON_CREATE=1

# If 1: send a short debug message in the group when the bot auto-tracks a post.
ANNOUNCE_AUTOTRACK=0
